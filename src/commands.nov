module conductor_commands;

import ../lib/std std;
import ../lib/file_io file_io;
import ../lib/env env;
import ../lib/process process;
import ../lib/time time;

import ui;
import storage;
import ai_api;

fn arg_at(argv: u64, index: i32) -> str {
    return std.argv_get(argv, index);
}

fn has_arg(argc: i32, argv: u64, name: str) -> bool {
    let i: i32 = 1;
    while (i < argc) {
        if (arg_at(argv, i) == name) { return true; }
        i = i + 1;
    }
    return false;
}

fn option_value(argc: i32, argv: u64, name: str, fallback: str) -> str {
    let i: i32 = 1;
    while (i < argc - 1) {
        if (arg_at(argv, i) == name) {
            return arg_at(argv, i + 1);
        }
        i = i + 1;
    }
    return fallback;
}

fn collect_message(argc: i32, argv: u64, start: i32) -> str {
    let out: str = "";
    let i: i32 = start;
    while (i < argc) {
        let a: str = arg_at(argv, i);
        if (std.starts_with(a, "--")) {
            i = i + 2;
        } else {
            if (std.len(out) > 0) { out = out + " "; }
            out = out + a;
            i = i + 1;
        }
    }
    return out;
}

fn command_run(argc: i32, argv: u64) -> i32 {
    storage_init();
    let provider: str = option_value(argc, argv, "--provider", "openrouter");
    let model: str = option_value(argc, argv, "--model", storage_get_active_model());
    let agent: str = option_value(argc, argv, "--agent", storage_get_active_agent());
    let file_path: str = option_value(argc, argv, "--file", "");
    let message: str = collect_message(argc, argv, 2);
    if (std.len(file_path) > 0) {
        if (!file_io.file_exists(file_path)) {
            ui_error("File not found: " + file_path);
            return 1;
        }
        message = message + "\n\nAttached file " + file_path + ":\n" + file_io.read_file(file_path);
    }
    if (std.len(std.trim(message)) == 0) {
        message = std.input("Message: ", 4096);
    }
    let response: str = "";
    if (ai_provider_exists(provider)) {
        response = ai_run(message, model, provider);
    } else {
        response = ai_placeholder_response(message, model, agent);
    }
    ui_logo();
    std.print("");
    std.print(response);
    let title: str = message;
    if (std.len(title) > 48) {
        title = std.substr_len(title, 0, 48);
    }
    let id: str = storage_record_session(title, message, response);
    std.print("");
    ui_kv("session", id);
    return 0;
}

fn first_word(line: str) -> str {
    return std.split_first(std.trim(line), " ");
}

fn rest_words(line: str) -> str {
    return std.trim(std.split_rest(std.trim(line), " "));
}

fn command_models(argc: i32, argv: u64) -> i32 {
    let verbose: bool = has_arg(argc, argv, "--verbose");
    let provider: str = "";
    if (argc >= 3 && !std.starts_with(arg_at(argv, 2), "--")) {
        provider = arg_at(argv, 2);
    }
    let rc: i32 = ai_print_models(provider, verbose);
    if (rc != 0) {
        ui_error("Provider not found: " + provider);
    }
    return rc;
}

fn command_providers(argc: i32, argv: u64) -> i32 {
    storage_init();
    storage_providers_init();
    if (argc >= 3 && arg_at(argv, 2) == "list") {
        std.print(storage_provider_list());
        return 0;
    }
    if (argc >= 3 && arg_at(argv, 2) == "add") {
        let name: str = option_value(argc, argv, "--name", "");
        let kind: str = option_value(argc, argv, "--kind", "openrouter");
        let conn: str = option_value(argc, argv, "--conn", "env:OPENROUTER_API_KEY");
        if (std.len(std.trim(name)) == 0) { ui_error("Usage: conductor providers add --name NAME --kind KIND --conn CONNECTION"); return 1; }
        let rc: i32 = storage_provider_create(name, kind, conn);
        if (rc == 0) { ui_ok("Provider added: " + name); return 0; }
        if (rc == 2) { ui_error("Provider already exists: " + name); return 1; }
        ui_error("Failed to add provider.");
        return 1;
    }
    if (argc >= 3 && arg_at(argv, 2) == "show") {
        if (argc < 4) { ui_error("Usage: conductor providers show <name>"); return 1; }
        let cfg: str = storage_provider_get(arg_at(argv, 3));
        if (std.len(std.trim(cfg)) == 0) { ui_error("Provider not found: " + arg_at(argv, 3)); return 1; }
        std.print(cfg);
        return 0;
    }
    if (argc >= 3 && arg_at(argv, 2) == "use") {
        if (argc < 4) { ui_error("Usage: conductor providers use <name>"); return 1; }
        let rc: i32 = storage_set_active_provider(arg_at(argv, 3));
        if (rc == 0) { ui_ok("Active provider: " + arg_at(argv, 3)); return 0; }
        ui_error("Provider not found: " + arg_at(argv, 3));
        return 1;
    }
    if (argc >= 3 && arg_at(argv, 2) == "delete") {
        if (argc < 4) { ui_error("Usage: conductor providers delete <name>"); return 1; }
        let rc: i32 = storage_provider_delete(arg_at(argv, 3));
        if (rc == 0) { ui_ok("Provider deleted: " + arg_at(argv, 3)); return 0; }
        ui_error("Provider not found: " + arg_at(argv, 3));
        return 1;
    }
    // default: list
    std.print(storage_provider_list());
    return 0;
}

fn command_agent(argc: i32, argv: u64) -> i32 {
    storage_init();
    if (argc >= 3 && arg_at(argv, 2) == "create") {
        let name: str = option_value(argc, argv, "--name", "conductor-agent");
        let desc: str = option_value(argc, argv, "--description", "Placeholder Conductor agent");
        let rc: i32 = storage_create_agent(name, desc, "all", "read,edit,glob,grep,bash,webfetch,task,mcp");
        if (rc == 0) { ui_ok("Agent created: " + name); return 0; }
        if (rc == 2) { ui_error("Agent already exists: " + name); return 1; }
        ui_error("Agent name is required.");
        return 1;
    }
    if (argc >= 3 && arg_at(argv, 2) == "use") {
        if (argc < 4) { ui_error("Usage: conductor agent use <name>"); return 1; }
        let rc: i32 = storage_set_active_agent(arg_at(argv, 3));
        if (rc == 0) { ui_ok("Active agent: " + arg_at(argv, 3)); return 0; }
        ui_error("Agent not found: " + arg_at(argv, 3));
        return 1;
    }
    if (argc >= 3 && arg_at(argv, 2) == "show") {
        let name: str = storage_get_active_agent();
        if (argc >= 4) { name = arg_at(argv, 3); }
        let rc: i32 = storage_print_agent(name);
        if (rc != 0) { ui_error("Agent not found: " + name); }
        return rc;
    }
    if (argc >= 3 && arg_at(argv, 2) == "current") {
        std.print(storage_get_active_agent());
        return 0;
    }
    if (argc >= 3 && arg_at(argv, 2) == "list") {
        storage_print_agents();
        return 0;
    }
    if (argc >= 3 && arg_at(argv, 2) == "delete") {
        if (argc < 4) { ui_error("Usage: conductor agent delete <name>"); return 1; }
        let rc: i32 = storage_delete_agent(arg_at(argv, 3));
        if (rc == 0) { ui_ok("Agent deleted: " + arg_at(argv, 3)); return 0; }
        if (rc == 2) { ui_error("The default agent cannot be deleted."); return 1; }
        ui_error("Agent not found: " + arg_at(argv, 3));
        return 1;
    }
    ui_error("Usage: conductor agent create|list|use|show|current|delete");
    return 1;
}

fn command_permission(argc: i32, argv: u64) -> i32 {
    storage_init();
    if (argc < 3 || arg_at(argv, 2) == "list") {
        storage_print_permissions();
        return 0;
    }
    if (arg_at(argv, 2) == "reset") {
        storage_permissions_reset();
        ui_ok("Permissions reset.");
        return 0;
    }
    if (argc < 4) {
        ui_error("Usage: conductor permission allow|deny|ask <tool>");
        return 1;
    }
    let action: str = arg_at(argv, 2);
    let tool: str = arg_at(argv, 3);
    if (!(action == "allow" || action == "deny" || action == "ask")) {
        ui_error("Permission action must be allow, deny, ask, list, or reset.");
        return 1;
    }
    let rc: i32 = storage_permission_set(tool, action);
    if (rc == 0) {
        ui_ok(tool + " = " + action);
        return 0;
    }
    if (rc == 1) {
        ui_error("Unknown tool: " + tool);
        return 1;
    }
    ui_error("Unknown permission value: " + action);
    return 1;
}

fn command_mcp(argc: i32, argv: u64) -> i32 {
    storage_init();
    let path: str = file_io.path_join(storage_root(), "mcp.txt");
    if (!file_io.file_exists(path)) {
        file_io.write_file(path, "");
    }
    if (argc >= 3 && (arg_at(argv, 2) == "list" || arg_at(argv, 2) == "ls")) {
        let content: str = file_io.read_file(path);
        if (std.len(std.trim(content)) == 0) {
            std.print("No MCP servers configured.");
            return 0;
        }
        std.print(content);
        return 0;
    }
    if (argc >= 3 && arg_at(argv, 2) == "add") {
        let name: str = option_value(argc, argv, "--name", "server");
        let url: str = option_value(argc, argv, "--url", "stdio://placeholder");
        file_io.file_append(path, name + " | " + url + " | placeholder\n");
        ui_ok("MCP server added: " + name);
        return 0;
    }
    ui_error("Usage: conductor mcp list|add --name NAME --url URL");
    return 1;
}

fn command_session(argc: i32, argv: u64) -> i32 {
    if (argc >= 3 && arg_at(argv, 2) == "list") {
        storage_print_sessions();
        return 0;
    }
    if (argc >= 4 && arg_at(argv, 2) == "delete") {
        let rc: i32 = storage_delete_session(arg_at(argv, 3));
        if (rc == 0) {
            ui_ok("Session deleted: " + arg_at(argv, 3));
        } else {
            ui_error("Session not found: " + arg_at(argv, 3));
        }
        return rc;
    }
    if (argc >= 3 && arg_at(argv, 2) == "resume") {
        let id: str = "";
        if (argc >= 4) { id = arg_at(argv, 3); }
        if (std.len(std.trim(id)) == 0) { ui_error("Usage: conductor session resume <sessionID>"); return 1; }
        let rc: i32 = storage_set_active_session(id);
        if (rc == 0) { ui_ok("Active session: " + id); return 0; }
        ui_error("Session not found: " + id);
        return 1;
    }
    if (argc >= 3 && arg_at(argv, 2) == "cleanup") {
        storage_cleanup_sessions();
        ui_ok("Sessions cleanup complete.");
        return 0;
    }
    ui_error("Usage: conductor session list|delete|resume|cleanup <sessionID>");
    return 1;
}

fn command_config(argc: i32, argv: u64) -> i32 {
    if (argc >= 3 && arg_at(argv, 2) == "path") {
        storage_init();
        std.print(storage_config_path());
        return 0;
    }
    if (argc >= 3 && arg_at(argv, 2) == "check") {
        let rc: i32 = storage_config_check();
        if (rc == 0) {
            ui_ok("No config warnings.");
        } else {
            ui_error("Config must contain provider= and model= entries.");
        }
        return rc;
    }
    storage_print_config();
    return 0;
}

fn command_stats() -> i32 {
    storage_print_stats();
    return 0;
}

fn command_status() -> i32 {
    std.print(storage_status_text());
    return 0;
}

fn command_tools() -> i32 {
    storage_init();
    std.print("Tool surfaces");
    std.print("-------------");
    let i: i32 = 0;
    while (i < storage_permission_tool_count()) {
        let tool: str = storage_permission_tool_at(i);
        std.print(tool + " | permission=" + storage_permission_get(tool));
        i = i + 1;
    }
    return 0;
}

fn command_doctor() -> i32 {
    storage_init();
    ui_header("Conductor doctor");
    ui_kv("version", conductor_version());
    ui_kv("home", storage_root());
    ui_kv("active agent", storage_get_active_agent());
    ui_kv("active model", storage_get_active_model());
    std.print("novus: installed");
    std.print("nox: installed");
    std.print("ai api: placeholder");
    return 0;
}

fn command_init_project() -> i32 {
    storage_init();
    if (!file_io.file_exists("AGENTS.md")) {
        file_io.write_file("AGENTS.md", "# Conductor project instructions\n\nDescribe project conventions, commands, permissions, and agent guidance here.\n");
        ui_ok("Created AGENTS.md");
    } else {
        ui_warn("AGENTS.md already exists.");
    }
    ui_ok("Conductor state ready at " + storage_root());
    return 0;
}

fn command_export(argc: i32, argv: u64) -> i32 {
    let path: str = "conductor-sessions.txt";
    if (argc >= 3) {
        path = arg_at(argv, 2);
    }
    let rc: i32 = storage_export(path);
    if (rc == 0) {
        ui_ok("Exported sessions to " + path);
    } else {
        ui_error("Failed to export sessions to " + path);
    }
    return rc;
}

fn command_import(argc: i32, argv: u64) -> i32 {
    if (argc < 3) {
        ui_error("Usage: conductor import <file>");
        return 1;
    }
    let rc: i32 = storage_import(arg_at(argv, 2));
    if (rc == 0) {
        ui_ok("Imported sessions from " + arg_at(argv, 2));
    } else {
        ui_error("File not found: " + arg_at(argv, 2));
    }
    return rc;
}

fn command_serve(argc: i32, argv: u64) -> i32 {
    let port: str = option_value(argc, argv, "--port", "4096");
    ui_warn("Headless server is a placeholder until Novus HTTP/runtime support is expanded.");
    std.print("conductor server placeholder listening on http://127.0.0.1:" + port);
    return 0;
}

fn command_generate() -> i32 {
    std.print(ai_openapi_placeholder());
    return 0;
}

fn command_remote() -> i32 {
    ui_warn("Remote/cloud session support is intentionally deferred behind the placeholder AI API controller.");
    return 0;
}

fn shell_run_message(message: str) -> void {
    let model: str = storage_get_active_model();
    let agent: str = storage_get_active_agent();
    std.print("You: " + message);
    let response: str = ai_placeholder_response(message, model, agent);
    std.print("Conductor: " + response);
    let title: str = message;
    if (std.len(title) > 48) { title = std.substr_len(title, 0, 48); }
    let id: str = storage_record_session(title, message, response);
    std.print("session " + id);
}

fn shell_agent_command(rest: str) -> void {
    let sub: str = first_word(rest);
    let args: str = rest_words(rest);
    if (std.len(sub) == 0 || sub == "list") {
        storage_print_agents();
        return;
    }
    if (sub == "use") {
        if (std.len(args) == 0) { ui_error("Usage: /agent use NAME"); return; }
        let rc: i32 = storage_set_active_agent(first_word(args));
        if (rc == 0) { ui_ok("Active agent: " + first_word(args)); return; }
        ui_error("Agent not found: " + first_word(args));
        return;
    }
    if (sub == "show") {
        let name: str = args;
        if (std.len(name) == 0) { name = storage_get_active_agent(); }
        let rc: i32 = storage_print_agent(first_word(name));
        if (rc != 0) { ui_error("Agent not found: " + first_word(name)); }
        return;
    }
    if (sub == "create") {
        let name: str = first_word(args);
        let desc: str = rest_words(args);
        if (std.len(name) == 0) { ui_error("Usage: /agent create NAME DESCRIPTION"); return; }
        let final_desc: str = desc;
        if (std.len(final_desc) == 0) { final_desc = "Interactive Conductor agent"; }
        let rc: i32 = storage_create_agent(name, final_desc, "all", "read,edit,glob,grep,bash,webfetch,task,mcp");
        if (rc == 0) { ui_ok("Agent created: " + name); return; }
        if (rc == 2) { ui_error("Agent already exists: " + name); return; }
        ui_error("Could not create agent.");
        return;
    }
    ui_error("Usage: /agent list|create|use|show");
}

fn shell_permission_command(rest: str) -> void {
    let sub: str = first_word(rest);
    let tool: str = first_word(rest_words(rest));
    if (std.len(sub) == 0 || sub == "list") {
        storage_print_permissions();
        return;
    }
    if (sub == "reset") {
        storage_permissions_reset();
        ui_ok("Permissions reset.");
        return;
    }
    if (!(sub == "allow" || sub == "deny" || sub == "ask")) {
        ui_error("Usage: /permission allow|deny|ask TOOL");
        return;
    }
    let rc: i32 = storage_permission_set(tool, sub);
    if (rc == 0) { ui_ok(tool + " = " + sub); return; }
    ui_error("Unknown tool: " + tool);
}

fn shell_handle_command(line: str) -> bool {
    let body: str = std.trim(std.substr(line, 1));
    let cmd: str = first_word(body);
    let rest: str = rest_words(body);
    if (cmd == "exit" || cmd == "quit" || cmd == "q") {
        std.print("Goodbye.");
        return false;
    }
    if (cmd == "help" || cmd == "?") { ui_shell_help(); return true; }
    if (cmd == "clear") { std.print("\n\n\n\n\n"); return true; }
    if (cmd == "status") { command_status(); return true; }
    if (cmd == "tools") { command_tools(); return true; }
    if (cmd == "sessions" || cmd == "session") {
        if (std.len(rest) == 0) { storage_print_sessions(); return true; }
        let sub: str = first_word(rest);
        let arg: str = rest_words(rest);
        if (sub == "cleanup") { storage_cleanup_sessions(); ui_ok("Sessions cleanup complete."); return true; }
        if (sub == "resume") {
            let id: str = first_word(arg);
            if (std.len(id) == 0) { ui_error("Usage: /sessions resume <sessionID>"); return true; }
            let rc: i32 = storage_set_active_session(id);
            if (rc == 0) { ui_ok("Active session: " + id); } else { ui_error("Session not found: " + id); }
            return true;
        }
        storage_print_sessions();
        return true;
    }
    if (cmd == "providers") {
        if (std.len(rest) == 0) { std.print(storage_provider_list()); return true; }
        let sub: str = first_word(rest);
        let arg: str = rest_words(rest);
        if (sub == "list") { std.print(storage_provider_list()); return true; }
        if (sub == "use") {
            let name: str = first_word(arg);
            if (std.len(name) == 0) { ui_error("Usage: /providers use NAME"); return true; }
            let rc: i32 = storage_set_active_provider(name);
            if (rc == 0) { ui_ok("Active provider: " + name); } else { ui_error("Provider not found: " + name); }
            return true;
        }
        if (sub == "show") {
            let name: str = first_word(arg);
            if (std.len(name) == 0) { ui_error("Usage: /providers show NAME"); return true; }
            let cfg: str = storage_provider_get(name);
            if (std.len(std.trim(cfg)) == 0) { ui_error("Provider not found: " + name); return true; }
            std.print(cfg);
            return true;
        }
        if (sub == "add") {
            // simple form: /providers add NAME KIND CONN
            let name: str = first_word(arg);
            let rest2: str = rest_words(arg);
            let kind: str = first_word(rest2);
            let conn: str = rest_words(rest2);
            if (std.len(name) == 0) { ui_error("Usage: /providers add NAME [KIND] [CONN]"); return true; }
            if (std.len(kind) == 0) { kind = "openrouter"; }
            if (std.len(conn) == 0) { conn = "env:OPENROUTER_API_KEY"; }
            let rc: i32 = storage_provider_create(name, kind, conn);
            if (rc == 0) { ui_ok("Provider added: " + name); } else { ui_error("Could not add provider: " + name); }
            return true;
        }
        if (sub == "delete") {
            let name: str = first_word(arg);
            if (std.len(name) == 0) { ui_error("Usage: /providers delete NAME"); return true; }
            let rc: i32 = storage_provider_delete(name);
            if (rc == 0) { ui_ok("Provider deleted: " + name); } else { ui_error("Provider not found: " + name); }
            return true;
        }
        std.print(storage_provider_list());
        return true;
    }
    if (cmd == "models") { ai_print_models(first_word(rest), false); return true; }
    if (cmd == "permissions" || cmd == "permission") { shell_permission_command(rest); return true; }
    if (cmd == "agent") { shell_agent_command(rest); return true; }
    if (cmd == "model") {
        if (std.len(rest) == 0) {
            std.print(storage_get_active_model());
        } else {
            storage_set_active_model(first_word(rest));
            ui_ok("Active model: " + first_word(rest));
        }
        return true;
    }
    if (cmd == "init") { command_init_project(); return true; }
    if (cmd == "doctor") { command_doctor(); return true; }
    if (cmd == "run") { shell_run_message(rest); return true; }
    ui_error("Unknown slash command: /" + cmd);
    return true;
}

fn command_chat() -> i32 {
    storage_init();
    // Cleanup empty sessions on startup
    storage_cleanup_sessions();
    // Create a new session for this Conductor process
    let session_title: str = "interactive " + std.to_str(time.get_time_ms());
    let sid: str = storage_create_session(session_title);
    ui_shell_banner(storage_get_active_agent(), storage_get_active_model());
    ui_kv("session", sid);
    let running: bool = true;
    let empty_reads: i32 = 0;
    while (running) {
        let line: str = std.trim(std.input("conductor> ", 4096));
        if (std.len(line) == 0) {
            empty_reads = empty_reads + 1;
            if (empty_reads >= 3) {
                std.print("No input received; leaving Conductor.");
                running = false;
            }
        } else if (std.starts_with(line, "/")) {
            empty_reads = 0;
            running = shell_handle_command(line);
        } else {
            empty_reads = 0;
            shell_run_message(line);
        }
    }
    return 0;
}

fn command_resume(argc: i32, argv: u64) -> i32 {
    storage_init();
    let id: str = "";
    if (argc >= 3) { id = arg_at(argv, 2); }
    if (std.len(std.trim(id)) == 0) { id = storage_last_session(); }
    if (std.len(std.trim(id)) == 0) { ui_error("No session to resume."); return 1; }
    let rc: i32 = storage_set_active_session(id);
    if (rc == 0) { ui_ok("Resumed session: " + id); return 0; }
    ui_error("Session not found: " + id);
    return rc;
}

fn conductor_dispatch(argc: i32, argv: u64) -> i32 {
    if (argc <= 1) {
        return command_chat();
    }
    let cmd: str = arg_at(argv, 1);
    if (cmd == "--help" || cmd == "-h" || cmd == "help") {
        ui_help();
        return 0;
    }
    if (cmd == "--version" || cmd == "-v" || cmd == "version") {
        ui_version();
        return 0;
    }
    if (cmd == "chat") { return command_chat(); }
    if (cmd == "run" || cmd == "prompt") { return command_run(argc, argv); }
    if (cmd == "resume") { return command_resume(argc, argv); }
    if (cmd == "models") { return command_models(argc, argv); }
    if (cmd == "providers") { return command_providers(); }
    if (cmd == "agent") { return command_agent(argc, argv); }
    if (cmd == "permission" || cmd == "permissions") { return command_permission(argc, argv); }
    if (cmd == "mcp") { return command_mcp(argc, argv); }
    if (cmd == "session") { return command_session(argc, argv); }
    if (cmd == "config") { return command_config(argc, argv); }
    if (cmd == "stats") { return command_stats(); }
    if (cmd == "status") { return command_status(); }
    if (cmd == "tools") { return command_tools(); }
    if (cmd == "doctor") { return command_doctor(); }
    if (cmd == "init") { return command_init_project(); }
    if (cmd == "export") { return command_export(argc, argv); }
    if (cmd == "import") { return command_import(argc, argv); }
    if (cmd == "serve") { return command_serve(argc, argv); }
    if (cmd == "generate") { return command_generate(); }
    if (cmd == "remote" || cmd == "attach") { return command_remote(); }
    ui_error("Unknown command: " + cmd);
    std.print("Run 'conductor help' for usage.");
    return 1;
}
