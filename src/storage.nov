module conductor_storage;

import ../lib/std std;
import ../lib/file_io file_io;
import ../lib/env env;
import ../lib/time time;

fn storage_root() -> str {
    let configured: str = env.getenv("CONDUCTOR_HOME");
    if (std.len(configured) > 0) {
        return configured;
    }
    return ".conductor";
}

fn storage_sessions_dir() -> str {
    return file_io.path_join(storage_root(), "sessions");
}

fn storage_config_path() -> str {
    return file_io.path_join(storage_root(), "config.txt");
}

fn storage_session_index_path() -> str {
    return file_io.path_join(storage_root(), "sessions.txt");
}

fn storage_stats_path() -> str {
    return file_io.path_join(storage_root(), "stats.txt");
}

fn storage_agents_dir() -> str {
    return file_io.path_join(storage_root(), "agents");
}

fn storage_agents_index_path() -> str {
    return file_io.path_join(storage_agents_dir(), "index.txt");
}

fn storage_active_agent_path() -> str {
    return file_io.path_join(storage_root(), "active-agent.txt");
}

fn storage_active_model_path() -> str {
    return file_io.path_join(storage_root(), "active-model.txt");
}

fn storage_env_path() -> str {
    return file_io.path_join(storage_root(), "env.txt");
}

fn storage_env_get(name: str) -> str {
    storage_init();
    let path: str = storage_env_path();
    if (!file_io.file_exists(path)) { return ""; }
    let content: str = file_io.read_file(path);
    let rest: str = content;
    while (std.len(std.trim(rest)) > 0) {
        let line: str = std.split_first(rest, "\n");
        rest = std.split_rest(rest, "\n");
        let ltrim: str = std.trim(line);
        if (std.len(ltrim) == 0) { continue; }
        if (std.starts_with(ltrim, "#")) { continue; }
        if (std.contains(ltrim, "=")) {
            let k: str = std.trim(std.split_first(ltrim, "="));
            let v: str = std.trim(std.split_rest(ltrim, "="));
            if (k == name) { return v; }
        }
    }
    return "";
}

fn storage_env_set(name: str, value: str) -> void {
    storage_init();
    let path: str = storage_env_path();
    let content: str = "";
    if (file_io.file_exists(path)) {
        content = file_io.read_file(path);
    }
    let rest: str = content;
    let out: str = "";
    let found: bool = false;
    while (std.len(std.trim(rest)) > 0) {
        let line: str = std.split_first(rest, "\n");
        rest = std.split_rest(rest, "\n");
        let ltrim: str = std.trim(line);
        if (std.len(ltrim) == 0) { out = out + line + "\n"; continue; }
        if (std.starts_with(ltrim, "#")) { out = out + line + "\n"; continue; }
        if (std.contains(ltrim, "=")) {
            let k: str = std.trim(std.split_first(ltrim, "="));
            if (k == name) {
                out = out + name + "=" + value + "\n";
                found = true;
            } else {
                out = out + ltrim + "\n";
            }
        } else {
            out = out + ltrim + "\n";
        }
    }
    if (!found) {
        out = out + name + "=" + value + "\n";
    }
    file_io.write_file(path, out);
}

fn storage_env_list() -> str {
    storage_init();
    let path: str = storage_env_path();
    if (!file_io.file_exists(path)) { return ""; }
    return file_io.read_file(path);
}

fn storage_permissions_dir() -> str {
    return file_io.path_join(storage_root(), "permissions");
}

fn storage_permission_path(tool: str) -> str {
    return file_io.path_join(storage_permissions_dir(), tool + ".txt");
}

fn storage_init() -> void {
    file_io.mkdirp(storage_root());
    file_io.mkdirp(storage_sessions_dir());
    file_io.mkdirp(storage_agents_dir());
    file_io.mkdirp(storage_permissions_dir());
    if (!file_io.file_exists(storage_config_path())) {
        file_io.write_file(storage_config_path(), "provider=openrouter-placeholder\nmodel=openrouter-placeholder/conductor-dev\n");
    }
    if (!file_io.file_exists(storage_session_index_path())) {
        file_io.write_file(storage_session_index_path(), "");
    }
    if (!file_io.file_exists(storage_stats_path())) {
        file_io.write_file(storage_stats_path(), "runs=0\n");
    }
    if (!file_io.file_exists(storage_active_agent_path())) {
        file_io.write_file(storage_active_agent_path(), "conductor-agent");
    }
    if (!file_io.file_exists(storage_active_model_path())) {
        file_io.write_file(storage_active_model_path(), "openrouter-placeholder/conductor-dev");
    }
    if (!file_io.file_exists(storage_agents_index_path())) {
        file_io.write_file(storage_agents_index_path(), "conductor-agent | all | Default terminal coding agent\n");
    }
    let default_agent_path: str = file_io.path_join(storage_agents_dir(), "conductor-agent.txt");
    if (!file_io.file_exists(default_agent_path)) {
        file_io.write_file(default_agent_path, "name=conductor-agent\ndescription=Default terminal coding agent\nmode=all\npermissions=read,edit,glob,grep,bash,webfetch,task,mcp\n");
    }
    // Ensure env store exists
    let env_path: str = storage_env_path();
    if (!file_io.file_exists(env_path)) { file_io.write_file(env_path, ""); }

    storage_permissions_bootstrap();
    // Ensure providers exist and set default active provider if missing
    storage_providers_init();
    if (!file_io.file_exists(storage_active_provider_path())) {
        file_io.write_file(storage_active_provider_path(), "openrouter");
    }
}

fn storage_new_session_id() -> str {
    let t: i64 = time.get_time_ms();
    return "session-" + std.to_str(t);
}

fn storage_active_session_path() -> str {
    return file_io.path_join(storage_root(), "active-session.txt");
}

fn storage_get_active_session() -> str {
    storage_init();
    if (!file_io.file_exists(storage_active_session_path())) {
        return "";
    }
    return std.trim(file_io.read_file(storage_active_session_path()));
}

fn storage_set_active_session(id: str) -> i32 {
    storage_init();
    let path: str = file_io.path_join(storage_sessions_dir(), id + ".txt");
    if (!file_io.file_exists(path)) {
        return 1;
    }
    file_io.write_file(storage_active_session_path(), id);
    return 0;
}

fn storage_create_session(title: str) -> str {
    storage_init();
    let id: str = storage_new_session_id();
    let file_name: str = id + ".txt";
    let path: str = file_io.path_join(storage_sessions_dir(), file_name);
    let t: i64 = time.get_time_ms();
    let body: str = "id=" + id + "\n";
    body = body + "title=" + title + "\n";
    body = body + "created_at=" + std.to_str(t) + "\n";
    file_io.write_file(path, body);
    file_io.file_append(storage_session_index_path(), id + " | " + title + "\n");
    file_io.write_file(storage_active_session_path(), id);
    return id;
}

fn storage_append_message(session_id: str, role: str, content: str) -> void {
    storage_init();
    let path: str = file_io.path_join(storage_sessions_dir(), session_id + ".txt");
    if (!file_io.file_exists(path)) { return; }
    let t: i64 = time.get_time_ms();
    file_io.file_append(path, "===MSG_START===\nrole=" + role + "\ntimestamp=" + std.to_str(t) + "\ncontent=\n" + content + "\n===MSG_END===\n");
}

fn storage_last_session() -> str {
    storage_init();
    let idx: str = file_io.read_file(storage_session_index_path());
    let rest: str = idx;
    let last_id: str = "";
    while (std.len(std.trim(rest)) > 0) {
        let line: str = std.split_first(rest, "\n");
        rest = std.split_rest(rest, "\n");
        let ltrim: str = std.trim(line);
        if (std.len(ltrim) > 0) {
            last_id = std.trim(std.split_first(ltrim, "|"));
        }
    }
    return last_id;
}

fn storage_cleanup_sessions() -> void {
    storage_init();
    let idx: str = file_io.read_file(storage_session_index_path());
    let rest: str = idx;
    let new_index: str = "";
    while (std.len(std.trim(rest)) > 0) {
        let line: str = std.split_first(rest, "\n");
        rest = std.split_rest(rest, "\n");
        let line_trim: str = std.trim(line);
        if (std.len(line_trim) == 0) { continue; }
        let id: str = std.trim(std.split_first(line_trim, "|"));
        let path: str = file_io.path_join(storage_sessions_dir(), id + ".txt");
        if (!file_io.file_exists(path)) {
            // skip missing files
        } else {
            let content: str = file_io.read_file(path);
            if (std.contains(content, "===MSG_START===")) {
                new_index = new_index + id + " | " + std.trim(std.split_rest(line_trim, "|")) + "\n";
            } else {
                file_io.file_delete(path);
            }
        }
    }
    file_io.write_file(storage_session_index_path(), new_index);
    let active: str = storage_get_active_session();
    if (std.len(std.trim(active)) > 0) {
        let active_path: str = file_io.path_join(storage_sessions_dir(), active + ".txt");
        if (!file_io.file_exists(active_path)) {
            if (file_io.file_exists(storage_active_session_path())) {
                file_io.file_delete(storage_active_session_path());
            }
        }
    }
}

fn storage_increment_runs() -> void {
    let content: str = file_io.read_file(storage_stats_path());
    let count: i32 = 0;
    if (std.starts_with(content, "runs=")) {
        count = std.to_i32(std.substr(content, 5));
    }
    count = count + 1;
    file_io.write_file(storage_stats_path(), "runs=" + std.to_str(count) + "\n");
}

fn storage_record_session(title: str, prompt: str, response: str) -> str {
    storage_init();
    let id: str = storage_get_active_session();
    if (std.len(std.trim(id)) == 0) {
        id = storage_create_session(title);
    }
    storage_append_message(id, "user", prompt);
    storage_append_message(id, "assistant", response);
    storage_increment_runs();
    return id;
}

fn storage_print_sessions() -> void {
    storage_init();
    let index: str = file_io.read_file(storage_session_index_path());
    if (std.len(std.trim(index)) == 0) {
        std.print("No sessions yet.");
        return;
    }
    std.print(index);
}

fn storage_delete_session(id: str) -> i32 {
    storage_init();
    let path: str = file_io.path_join(storage_sessions_dir(), id + ".txt");
    if (!file_io.file_exists(path)) {
        let idx_content: str = file_io.read_file(storage_session_index_path());
        let rest: str = idx_content;
        let new_index: str = "";
        while (std.len(std.trim(rest)) > 0) {
            let line: str = std.split_first(rest, "\n");
            rest = std.split_rest(rest, "\n");
            let lt: str = std.trim(line);
            if (std.len(lt) == 0) { continue; }
            let curid: str = std.trim(std.split_first(lt, "|"));
            if (curid != id) {
                new_index = new_index + lt + "\n";
            }
        }
        file_io.write_file(storage_session_index_path(), new_index);
        return 1;
    }
    file_io.file_delete(path);
    let idx_content: str = file_io.read_file(storage_session_index_path());
    let rest: str = idx_content;
    let new_index: str = "";
    while (std.len(std.trim(rest)) > 0) {
        let line: str = std.split_first(rest, "\n");
        rest = std.split_rest(rest, "\n");
        let lt: str = std.trim(line);
        if (std.len(lt) == 0) { continue; }
        let curid: str = std.trim(std.split_first(lt, "|"));
        if (curid != id) {
            new_index = new_index + lt + "\n";
        }
    }
    file_io.write_file(storage_session_index_path(), new_index);
    if (storage_get_active_session() == id) {
        if (file_io.file_exists(storage_active_session_path())) {
            file_io.file_delete(storage_active_session_path());
        }
    }
    return 0;
}

fn storage_print_config() -> void {
    storage_init();
    std.print(file_io.read_file(storage_config_path()));
}

fn storage_config_check() -> i32 {
    storage_init();
    let cfg: str = file_io.read_file(storage_config_path());
    if (!std.contains(cfg, "provider=")) {
        return 1;
    }
    if (!std.contains(cfg, "model=")) {
        return 1;
    }
    return 0;
}

fn storage_print_stats() -> void {
    storage_init();
    std.print(file_io.read_file(storage_stats_path()));
}

fn storage_export(path: str) -> i32 {
    storage_init();
    return file_io.write_file(path, file_io.read_file(storage_session_index_path()));
}

fn storage_import(path: str) -> i32 {
    storage_init();
    if (!file_io.file_exists(path)) {
        return 1;
    }
    let content: str = file_io.read_file(path);
    file_io.file_append(storage_session_index_path(), content);
    return 0;
}

fn storage_permission_default(tool: str) -> str {
    if (tool == "read") { return "allow"; }
    if (tool == "glob") { return "allow"; }
    if (tool == "grep") { return "allow"; }
    if (tool == "webfetch") { return "allow"; }
    if (tool == "edit") { return "ask"; }
    if (tool == "write") { return "ask"; }
    if (tool == "bash") { return "ask"; }
    if (tool == "task") { return "ask"; }
    if (tool == "mcp") { return "ask"; }
    return "ask";
}

fn storage_permission_tool_count() -> i32 {
    return 9;
}

fn storage_permission_tool_at(index: i32) -> str {
    if (index == 0) { return "read"; }
    if (index == 1) { return "glob"; }
    if (index == 2) { return "grep"; }
    if (index == 3) { return "webfetch"; }
    if (index == 4) { return "edit"; }
    if (index == 5) { return "write"; }
    if (index == 6) { return "bash"; }
    if (index == 7) { return "task"; }
    if (index == 8) { return "mcp"; }
    return "";
}

fn storage_permissions_bootstrap() -> void {
    let i: i32 = 0;
    while (i < storage_permission_tool_count()) {
        let tool: str = storage_permission_tool_at(i);
        let path: str = storage_permission_path(tool);
        if (!file_io.file_exists(path)) {
            file_io.write_file(path, storage_permission_default(tool));
        }
        i = i + 1;
    }
}

fn storage_permission_exists(tool: str) -> bool {
    let i: i32 = 0;
    while (i < storage_permission_tool_count()) {
        if (storage_permission_tool_at(i) == tool) { return true; }
        i = i + 1;
    }
    return false;
}

fn storage_permission_get(tool: str) -> str {
    storage_init();
    if (!storage_permission_exists(tool)) {
        return "unknown";
    }
    return std.trim(file_io.read_file(storage_permission_path(tool)));
}

fn storage_permission_set(tool: str, value: str) -> i32 {
    storage_init();
    if (!storage_permission_exists(tool)) {
        return 1;
    }
    if (!(value == "allow" || value == "deny" || value == "ask")) {
        return 2;
    }
    file_io.write_file(storage_permission_path(tool), value);
    return 0;
}

fn storage_permissions_reset() -> void {
    storage_init();
    let i: i32 = 0;
    while (i < storage_permission_tool_count()) {
        let tool: str = storage_permission_tool_at(i);
        file_io.write_file(storage_permission_path(tool), storage_permission_default(tool));
        i = i + 1;
    }
}

fn storage_print_permissions() -> void {
    storage_init();
    std.print("Tool permissions");
    std.print("----------------");
    let i: i32 = 0;
    while (i < storage_permission_tool_count()) {
        let tool: str = storage_permission_tool_at(i);
        std.print(tool + " = " + storage_permission_get(tool));
        i = i + 1;
    }
}

fn storage_permission_default_path() -> str {
    return file_io.path_join(storage_root(), "permission-default.txt");
}

fn storage_set_permission_default(val: str) -> void {
    storage_init();
    file_io.write_file(storage_permission_default_path(), val);
}

fn storage_get_permission_default() -> str {
    storage_init();
    let path: str = storage_permission_default_path();
    if (!file_io.file_exists(path)) { return "ask"; }
    return std.trim(file_io.read_file(path));
}

fn storage_get_active_agent() -> str {
    storage_init();
    return std.trim(file_io.read_file(storage_active_agent_path()));
}

fn storage_get_active_model() -> str {
    storage_init();
    return std.trim(file_io.read_file(storage_active_model_path()));
}

fn storage_set_active_agent(name: str) -> i32 {
    storage_init();
    if (!storage_agent_exists(name)) {
        return 1;
    }
    file_io.write_file(storage_active_agent_path(), name);
    return 0;
}

fn storage_set_active_model(model: str) -> void {
    storage_init();
    file_io.write_file(storage_active_model_path(), model);
}

fn storage_agent_path(name: str) -> str {
    return file_io.path_join(storage_agents_dir(), name + ".txt");
}

fn storage_agent_exists(name: str) -> bool {
    storage_init();
    return file_io.file_exists(storage_agent_path(name));
}

fn storage_providers_dir() -> str {
    return file_io.path_join(storage_root(), "providers");
}

fn storage_provider_index_path() -> str {
    return file_io.path_join(storage_providers_dir(), "index.txt");
}

fn storage_provider_path(name: str) -> str {
    return file_io.path_join(storage_providers_dir(), name + ".txt");
}

fn storage_providers_init() -> void {
    file_io.mkdirp(storage_providers_dir());
    if (!file_io.file_exists(storage_provider_index_path())) {
        file_io.write_file(storage_provider_index_path(), "openrouter | env:OPENROUTER_API_KEY | default\n");
    }
    // create provider file for default if missing
    let ppath: str = storage_provider_path("openrouter");
    if (!file_io.file_exists(ppath)) {
        file_io.write_file(ppath, "name=openrouter\nkind=openrouter\nconnection=env:OPENROUTER_API_KEY\n");
    }
}

fn storage_provider_create(name: str, kind: str, conn: str) -> i32 {
    storage_init();
    storage_providers_init();
    if (std.len(std.trim(name)) == 0) { return 1; }
    let path: str = storage_provider_path(name);
    if (file_io.file_exists(path)) { return 2; }
    file_io.write_file(path, "name=" + name + "\nkind=" + kind + "\nconnection=" + conn + "\n");
    file_io.file_append(storage_provider_index_path(), name + " | " + conn + " | " + kind + "\n");
    return 0;
}

fn storage_provider_exists(name: str) -> bool {
    storage_providers_init();
    return file_io.file_exists(storage_provider_path(name));
}

fn storage_provider_list() -> str {
    storage_providers_init();
    return file_io.read_file(storage_provider_index_path());
}

fn storage_provider_get(name: str) -> str {
    storage_providers_init();
    if (!file_io.file_exists(storage_provider_path(name))) { return ""; }
    return file_io.read_file(storage_provider_path(name));
}

fn storage_active_provider_path() -> str {
    return file_io.path_join(storage_root(), "active-provider.txt");
}

fn storage_get_active_provider() -> str {
    storage_init();
    if (!file_io.file_exists(storage_active_provider_path())) { return ""; }
    return std.trim(file_io.read_file(storage_active_provider_path()));
}

fn storage_set_active_provider(name: str) -> i32 {
    storage_init();
    if (!storage_provider_exists(name)) { return 1; }
    file_io.write_file(storage_active_provider_path(), name);
    return 0;
}

fn storage_provider_delete(name: str) -> i32 {
    storage_providers_init();
    if (!file_io.file_exists(storage_provider_path(name))) { return 1; }
    file_io.file_delete(storage_provider_path(name));
    let idx: str = file_io.read_file(storage_provider_index_path());
    let rest: str = idx;
    let new_index: str = "";
    while (std.len(std.trim(rest)) > 0) {
        let line: str = std.split_first(rest, "\n");
        rest = std.split_rest(rest, "\n");
        let lt: str = std.trim(line);
        if (std.len(lt) == 0) { continue; }
        let pname: str = std.trim(std.split_first(lt, "|"));
        if (pname != name) { new_index = new_index + lt + "\n"; }
    }
    file_io.write_file(storage_provider_index_path(), new_index);
    // If deleted provider was active, unset active provider
    let active_path: str = file_io.path_join(storage_root(), "active-provider.txt");
    if (file_io.file_exists(active_path)) {
        let cur: str = std.trim(file_io.read_file(active_path));
        if (cur == name) { file_io.file_delete(active_path); }
    }
    return 0;
}

fn storage_create_agent(name: str, desc: str, mode: str, perms: str) -> i32 {
    storage_init();
    if (std.len(std.trim(name)) == 0) {
        return 1;
    }
    let path: str = storage_agent_path(name);
    if (file_io.file_exists(path)) {
        return 2;
    }
    file_io.write_file(path, "name=" + name + "\ndescription=" + desc + "\nmode=" + mode + "\npermissions=" + perms + "\n");
    file_io.file_append(storage_agents_index_path(), name + " | " + mode + " | " + desc + "\n");
    return 0;
}

fn storage_delete_agent(name: str) -> i32 {
    storage_init();
    if (name == "conductor-agent") {
        return 2;
    }
    if (!storage_agent_exists(name)) {
        return 1;
    }
    file_io.file_delete(storage_agent_path(name));
    if (storage_get_active_agent() == name) {
        file_io.write_file(storage_active_agent_path(), "conductor-agent");
    }
    return 0;
}

fn storage_print_agents() -> void {
    storage_init();
    std.print(file_io.read_file(storage_agents_index_path()));
}

fn storage_print_agent(name: str) -> i32 {
    storage_init();
    if (!storage_agent_exists(name)) {
        return 1;
    }
    std.print(file_io.read_file(storage_agent_path(name)));
    return 0;
}

fn storage_status_text() -> str {
    storage_init();
    return "home=" + storage_root() + "\nagent=" + storage_get_active_agent() + "\nmodel=" + storage_get_active_model() + "\n";
}
