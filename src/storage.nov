module conductor_storage;

import ../lib/std std;
import ../lib/file_io file_io;
import ../lib/env env;
import ../lib/time time;

fn storage_root() -> str {
    let configured: str = env.getenv("CONDUCTOR_HOME");
    if (std.len(configured) > 0) {
        return configured;
    }
    return ".conductor";
}

fn storage_sessions_dir() -> str {
    return file_io.path_join(storage_root(), "sessions");
}

fn storage_config_path() -> str {
    return file_io.path_join(storage_root(), "config.txt");
}

fn storage_session_index_path() -> str {
    return file_io.path_join(storage_root(), "sessions.txt");
}

fn storage_stats_path() -> str {
    return file_io.path_join(storage_root(), "stats.txt");
}

fn storage_init() -> void {
    file_io.mkdirp(storage_root());
    file_io.mkdirp(storage_sessions_dir());
    if (!file_io.file_exists(storage_config_path())) {
        file_io.write_file(storage_config_path(), "provider=openrouter-placeholder\nmodel=openrouter-placeholder/conductor-dev\n");
    }
    if (!file_io.file_exists(storage_session_index_path())) {
        file_io.write_file(storage_session_index_path(), "");
    }
    if (!file_io.file_exists(storage_stats_path())) {
        file_io.write_file(storage_stats_path(), "runs=0\n");
    }
}

fn storage_new_session_id() -> str {
    let t: i64 = time.get_time_ms();
    return "session-" + std.to_str(t);
}

fn storage_increment_runs() -> void {
    let content: str = file_io.read_file(storage_stats_path());
    let count: i32 = 0;
    if (std.starts_with(content, "runs=")) {
        count = std.to_i32(std.substr(content, 5));
    }
    count = count + 1;
    file_io.write_file(storage_stats_path(), "runs=" + std.to_str(count) + "\n");
}

fn storage_record_session(title: str, prompt: str, response: str) -> str {
    storage_init();
    let id: str = storage_new_session_id();
    let file_name: str = id + ".txt";
    let path: str = file_io.path_join(storage_sessions_dir(), file_name);
    let body: str = "id=" + id + "\n";
    body = body + "title=" + title + "\n";
    body = body + "prompt=" + prompt + "\n";
    body = body + "response=" + response + "\n";
    file_io.write_file(path, body);
    file_io.file_append(storage_session_index_path(), id + " | " + title + "\n");
    storage_increment_runs();
    return id;
}

fn storage_print_sessions() -> void {
    storage_init();
    let index: str = file_io.read_file(storage_session_index_path());
    if (std.len(std.trim(index)) == 0) {
        std.print("No sessions yet.");
        return;
    }
    std.print(index);
}

fn storage_delete_session(id: str) -> i32 {
    storage_init();
    let path: str = file_io.path_join(storage_sessions_dir(), id + ".txt");
    if (!file_io.file_exists(path)) {
        return 1;
    }
    file_io.file_delete(path);
    return 0;
}

fn storage_print_config() -> void {
    storage_init();
    std.print(file_io.read_file(storage_config_path()));
}

fn storage_config_check() -> i32 {
    storage_init();
    let cfg: str = file_io.read_file(storage_config_path());
    if (!std.contains(cfg, "provider=")) {
        return 1;
    }
    if (!std.contains(cfg, "model=")) {
        return 1;
    }
    return 0;
}

fn storage_print_stats() -> void {
    storage_init();
    std.print(file_io.read_file(storage_stats_path()));
}

fn storage_export(path: str) -> i32 {
    storage_init();
    return file_io.write_file(path, file_io.read_file(storage_session_index_path()));
}

fn storage_import(path: str) -> i32 {
    storage_init();
    if (!file_io.file_exists(path)) {
        return 1;
    }
    let content: str = file_io.read_file(path);
    file_io.file_append(storage_session_index_path(), content);
    return 0;
}
